# Gemini API key used by llm-structure/run commands
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# KIS API credentials used by `stockotter_small kis auth-test`
KIS_APP_KEY=YOUR_KIS_APP_KEY
KIS_APP_SECRET=YOUR_KIS_APP_SECRET
KIS_ACCOUNT=12345678
KIS_ENV=paper

# Optional overrides for Makefile targets
# CONFIG=config/config.yaml
# TICKERS_FILE=data/seed_tickers.txt
# SINCE_HOURS=72
# TOP=10
# DB_PATH=data/storage/stockotter.db
# CACHE_DIR=data/cache/raw
# JSON_OUT=data/reports/candidates_top10.json
